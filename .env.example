# Optional — alles hat sinnvolle Defaults. Kopie nach `.env` nur bei Bedarf.

# HELLES_PORT=3847
# `npm run dev` überschreibt mit HELLES_PORT=3848 (parallel zu systemd möglich).

# HELLES_HOST=0.0.0.0
# Hinter Reverse-Proxy: HELLES_TRUST_PROXY=1

# VITE_DEV_PORT=5173
# HELLES_DATA_DIR=./data
# HELLES_MAX_UPLOAD_MB=200
# Nach letztem WebSocket: Chat leeren nach N ms (Default 15000). 0 = sofort (riskant bei Tab-Refresh).
# HELLES_ROOM_RESET_MS=15000
# TLS (Production): nötig für Web Crypto auf https://<LAN-IP> — z. B. mkcert
# HELLES_HTTPS_KEY_PATH=/path/to/key.pem
# HELLES_HTTPS_CERT_PATH=/path/to/cert.pem
